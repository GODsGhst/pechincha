{
  "expo": {
    "name": "Pechincha",
    "slug": "pechincha",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pechincha",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "extra": {
      "apiUrl": "https://consult-price-api.onrender.com/api"
    },
    "splash": {
      "backgroundColor": "#0E3D2A",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "O Pechincha usa a câmera para ler o QR Code dos cupons fiscais."
      }
    },
    "android": {
      "package": "com.consultprice.app",
      "adaptiveIcon": {
        "backgroundColor": "#0E3D2A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": ["CAMERA", "ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "O Pechincha usa a câmera para ler o QR Code dos cupons fiscais."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "O Pechincha usa sua localização para mostrar lojas próximas."
        }
      ]
    ]
  }
}
