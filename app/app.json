{
  "expo": {
    "name": "Pechincha",
    "slug": "pechincha",
    "version": "1.0.10",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pechincha",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "extra": {
      "apiUrl": "https://consult-price-api.onrender.com/api"
    },
    "splash": {
      "backgroundColor": "#0E3D2A",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "com.consultprice.app",
      "buildNumber": "11",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "O Pechincha usa a câmera para ler o QR Code dos cupons fiscais.",
        "NSPhotoLibraryUsageDescription": "O Pechincha usa suas fotos apenas para escolher uma imagem do QR Code do cupom fiscal.",
        "NSLocationWhenInUseUsageDescription": "O Pechincha usa sua localização para mostrar lojas próximas.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.consultprice.app",
      "versionCode": 11,
      "adaptiveIcon": {
        "backgroundColor": "#0E3D2A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "O Pechincha usa a câmera para ler o QR Code dos cupons fiscais."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O Pechincha usa suas fotos apenas para escolher uma imagem do QR Code do cupom fiscal.",
          "microphonePermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "O Pechincha usa sua localização para mostrar lojas próximas."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false
          }
        }
      ]
    ]
  }
}
